# Copy this file to deploy/hostinger/stack.env on the VPS and fill the secrets.
# Do not commit the filled file.

NODE_ENV=production
ENV_FILE=/app/deploy/hostinger/stack.env

POSTGRES_DB=autopoly
POSTGRES_USER=autopoly
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgres://autopoly:replace-with-strong-password@postgres:5432/autopoly
DATABASE_READONLY_URL=postgres://autopoly:replace-with-strong-password@postgres:5432/autopoly
REDIS_URL=redis://redis:6379

APP_URL=https://example.com
AUTOPOLY_EXECUTION_MODE=live
ARTIFACT_STORAGE_ROOT=/app/runtime-artifacts

ORCHESTRATOR_INTERNAL_TOKEN=replace-with-long-random-token

PRIVATE_KEY=0x...
FUNDER_ADDRESS=0x...
SIGNATURE_TYPE=1
POLYMARKET_HOST=https://clob.polymarket.com
CHAIN_ID=137
DEFAULT_ORDER_TYPE=FOK

POLY_CLI_ENABLED=true
POLY_CLI_COMMAND=
POLY_CLI_STRICT=false

AGENT_RUNTIME_PROVIDER=codex
AGENT_DECISION_STRATEGY=pulse-direct
PROVIDER_TIMEOUT_SECONDS=0

DRAWDOWN_STOP_PCT=0.2
POSITION_STOP_LOSS_PCT=0.3
MAX_TOTAL_EXPOSURE_PCT=0.5
MAX_EVENT_EXPOSURE_PCT=0.3
MAX_POSITIONS=10
MAX_TRADE_PCT=0.1
MIN_TRADE_USD=0.01
INITIAL_BANKROLL_USD=20

PULSE_SOURCE_REPO=all-polymarket-skill
PULSE_SOURCE_REPO_DIR=/app/vendor/repos/all-polymarket-skill
PULSE_FETCH_TIMEOUT_SECONDS=60
PULSE_PAGES=1
PULSE_EVENTS_PER_PAGE=20
PULSE_MIN_LIQUIDITY_USD=5000
PULSE_MAX_CANDIDATES=12
PULSE_REPORT_CANDIDATES=4
PULSE_REPORT_COMMENT_LIMIT=20
PULSE_REPORT_TIMEOUT_SECONDS=0
PULSE_MIN_TRADEABLE_CANDIDATES=5
PULSE_MAX_AGE_MINUTES=30
PULSE_MAX_MARKDOWN_CHARS=24000

CODEX_COMMAND=
CODEX_MODEL=
CODEX_SKILL_ROOT_DIR=/app/vendor/repos/all-polymarket-skill
CODEX_SKILL_LOCALE=zh
CODEX_SKILLS=polymarket-market-pulse,portfolio-review-polymarket,poly-position-monitor,poly-resolution-tracking,api-trade-polymarket

OPENCLAW_COMMAND=
OPENCLAW_MODEL=
OPENCLAW_SKILL_ROOT_DIR=/app/vendor/repos/all-polymarket-skill
OPENCLAW_SKILL_LOCALE=zh
OPENCLAW_SKILLS=polymarket-market-pulse,portfolio-review-polymarket,poly-position-monitor,poly-resolution-tracking,api-trade-polymarket
