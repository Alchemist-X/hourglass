{
  "name": "autonomous-poly-trading",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently -n web,orchestrator,executor -c auto \"pnpm --filter @autopoly/web dev\" \"pnpm --filter @autopoly/orchestrator dev\" \"pnpm --filter @autopoly/executor dev\"",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "db:generate": "pnpm --filter @autopoly/db drizzle-kit generate",
    "db:migrate": "pnpm --filter @autopoly/db drizzle-kit migrate",
    "db:seed": "pnpm --filter @autopoly/db seed",
    "ave:demo": "tsx scripts/ave-demo.ts",
    "ave:live": "tsx scripts/ave-live.ts",
    "ave:recommend": "tsx scripts/ave-live.ts --recommend-only"
  },
  "dependencies": {
    "@autopoly/contracts": "workspace:*",
    "@autopoly/db": "workspace:*",
    "@autopoly/terminal-ui": "workspace:*",
    "bullmq": "5.71.0",
    "drizzle-orm": "0.45.1",
    "ioredis": "5.10.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "concurrently": "9.2.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
