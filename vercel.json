{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @autopoly/contracts build && pnpm --filter @autopoly/db build && pnpm --filter @autopoly/web build",
  "outputDirectory": "apps/web/.next",
  "experimentalServices": {
    "web": {
      "entrypoint": "apps/web",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "executor": {
      "entrypoint": "services/executor",
      "routePrefix": "/_/executor"
    },
    "orchestrator": {
      "entrypoint": "services/orchestrator",
      "routePrefix": "/_/orchestrator"
    }
  }
}
