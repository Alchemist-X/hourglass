# Shared settings
NODE_ENV=development
ENV_FILE=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/autopoly
DATABASE_READONLY_URL=postgres://postgres:postgres@localhost:5432/autopoly
REDIS_URL=redis://localhost:6379
APP_URL=http://localhost:3000
AUTOPOLY_EXECUTION_MODE=live
# Leave empty to use the default paper file at runtime-artifacts/local/paper-state.json when AUTOPOLY_EXECUTION_MODE=paper
AUTOPOLY_LOCAL_STATE_FILE=

# Dedicated live-test env files should pin these values:
# ENV_FILE=.env.live-test
# INITIAL_BANKROLL_USD=20
# MAX_TRADE_PCT=0.1
# MAX_EVENT_EXPOSURE_PCT=0.3
# MIN_TRADE_USD=0.01
# PULSE_LIVE_MAX_BUY_TOKENS=1
# PULSE_LIVE_MIN_TRADE_USD=0.01

# Web site
ADMIN_PASSWORD=change-me
ORCHESTRATOR_INTERNAL_URL=http://localhost:4001
ORCHESTRATOR_INTERNAL_TOKEN=replace-me

# Executor
PRIVATE_KEY=0x...
FUNDER_ADDRESS=0x...
SIGNATURE_TYPE=1
POLYMARKET_HOST=https://clob.polymarket.com
CHAIN_ID=137
DEFAULT_ORDER_TYPE=FOK
# Prefer the internal poly-cli bridge for Polymarket I/O.
POLY_CLI_ENABLED=true
# Optional custom command, for example: "pnpm exec tsx"
POLY_CLI_COMMAND=
# If true, read operations also fail hard when poly-cli fails.
POLY_CLI_STRICT=false

# Orchestrator schedules and hard risk limits
AGENT_POLL_CRON=0 */3 * * *
SYNC_INTERVAL_SECONDS=30
BACKTEST_CRON=10 0 * * *
RESOLUTION_BASE_INTERVAL_MINUTES=60
RESOLUTION_URGENT_INTERVAL_MINUTES=15
DRAWDOWN_STOP_PCT=0.2
POSITION_STOP_LOSS_PCT=0.3
MAX_TOTAL_EXPOSURE_PCT=0.5
MAX_EVENT_EXPOSURE_PCT=0.3
MAX_POSITIONS=10
MAX_TRADE_PCT=0.1
MIN_TRADE_USD=10
INITIAL_BANKROLL_USD=10000

# Orchestrator runtime
AGENT_RUNTIME_PROVIDER=codex
ARTIFACT_STORAGE_ROOT=runtime-artifacts
PROVIDER_TIMEOUT_SECONDS=0
PULSE_TIMEOUT_MODE=default

# Pulse storage and market discovery
PULSE_SOURCE_REPO=all-polymarket-skill
PULSE_SOURCE_REPO_DIR=vendor/repos/all-polymarket-skill
PULSE_FETCH_TIMEOUT_SECONDS=300
PULSE_PAGES=5
PULSE_EVENTS_PER_PAGE=50
PULSE_MIN_FETCHED_MARKETS=5000
PULSE_MIN_LIQUIDITY_USD=5000
PULSE_MAX_CANDIDATES=12
PULSE_REPORT_CANDIDATES=4
PULSE_REPORT_COMMENT_LIMIT=20
PULSE_REPORT_TIMEOUT_SECONDS=0
PULSE_DIRECT_RENDER_TIMEOUT_SECONDS=1200
PULSE_MIN_TRADEABLE_CANDIDATES=5
PULSE_MAX_AGE_MINUTES=30
PULSE_MAX_MARKDOWN_CHARS=24000

# Codex provider
CODEX_COMMAND=
CODEX_MODEL=
CODEX_SKILL_ROOT_DIR=vendor/repos/all-polymarket-skill
CODEX_SKILL_LOCALE=zh
CODEX_SKILLS=polymarket-market-pulse,portfolio-review-polymarket,poly-position-monitor,poly-resolution-tracking,api-trade-polymarket

# OpenClaw provider
OPENCLAW_COMMAND=
OPENCLAW_MODEL=
OPENCLAW_SKILL_ROOT_DIR=vendor/repos/all-polymarket-skill
OPENCLAW_SKILL_LOCALE=zh
OPENCLAW_SKILLS=polymarket-market-pulse,portfolio-review-polymarket,poly-position-monitor,poly-resolution-tracking,api-trade-polymarket

# Rough Loop
ROUGH_LOOP_PROVIDER=codex
ROUGH_LOOP_FILE=rough-loop.md
ROUGH_LOOP_POLL_SECONDS=60
ROUGH_LOOP_MAX_RETRIES=3
ROUGH_LOOP_TASK_TIMEOUT_MINUTES=45
ROUGH_LOOP_REQUIRE_CLEAN_TREE=1
ROUGH_LOOP_RELAX_GUARDRAILS=0
ROUGH_LOOP_AUTO_COMMIT=1
ROUGH_LOOP_AUTO_PUSH=0
ROUGH_LOOP_PAUSE_FILE=.rough-loop.pause

# AVE Data API
AVE_API_KEY=your-ave-api-key-here
AVE_API_BASE_URL=https://openapi.avedata.org/api/v1
AVE_MONITORING_CHAINS=ethereum,bsc,polygon,base,solana
AVE_PULSE_TOKEN_LIMIT=300
AVE_PULSE_TRENDING_LIMIT=50
